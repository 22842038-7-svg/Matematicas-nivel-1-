background:white;
border-radius:20px;
position:relative;
overflow:hidden;
}

#mono{
font-size:70px;
position:absolute;
left:0;
top:20px;
transition:.4s;
}

.walk{
animation:walk .4s;
}

@keyframes walk{
0%{transform:translateY(0);}
50%{transform:translateY(-5px);}
100%{transform:translateY(0);}
}

