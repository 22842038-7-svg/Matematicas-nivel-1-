<body>

<!-- INSTRUCCIONES -->
<div id="panelInstrucciones">
<div class="caja">
<h2>🎮 Instrucciones</h2>
<p>✔ Arrastra la respuesta correcta</p>
<p>✔ Tienes 3 vidas</p>
<p>✔ Si fallas pierdes una vida</p>
<p>✔ Si aciertas avanzas</p>
<button onclick="iniciarJuego()">Empezar</button>
</div>
</div>

<header class="barra-superior">
<div class="usuario">
<img src="img/avatar.png">
<span>Estudiante</span>
</div>

<div class="online">
<div class="dot"></div>
<span>En línea</span>
</div>

<div class="puntaje">⭐</div>
</header>

<div class="contenedor-juego">

<h1>🐵 Aventura de Divisiones</h1>

<div class="vidas">❤️ Vidas: <span id="vidas">3</span></div>

<div class="escenario">
<div id="mono">🐵</div>
<div class="meta">🍌</div>
</div>

<div class="bloque-pregunta">

<div class="pregunta">
<h2></h2>
</div>

<div class="opciones">
<div class="respuesta" draggable="true"></div>
<div class="respuesta" draggable="true"></div>
<div class="respuesta" draggable="true"></div>
</div>

</div>

<div id="zonaRespuesta">Suelta aquí</div>

<div id="mensaje"></div>

</div>

<audio id="bien" src="sonido/bien.mp3"></audio>
<audio id="error" src="sonido/error.mp3"></audio>

<script>
const preguntas=[
{a:12,b:3},
{a:16,b:4},
{a:20,b:5},
{a:18,b:3},
{a:24,b:4}
];

let i=0;
let correcta=0;
let monoPos=0;
let vidas=3;
let terminado=false;

const mono=document.getElementById("mono");
const msg=document.getElementById("mensaje");

let vozActual = null;

/* 🔥 VOZ QUE ESPERA TERMINAR */
function hablar(texto){
return new Promise(resolve=>{
speechSynthesis.cancel();

vozActual = new SpeechSynthesisUtterance(texto);
vozActual.lang="es-ES";
vozActual.rate=0.95;

vozActual.onend = resolve;

speechSynthesis.speak(vozActual);
});
}

/* 🔥 INICIO CON INSTRUCCIONES COMPLETAS */
function iniciarJuego(){

document.getElementById("panelInstrucciones").style.display="none";

hablar(
"Bienvenido al juego. Arrastra la respuesta correcta. Tienes tres vidas. Si fallas pierdes una vida. Si aciertas avanzas. Comenzamos"
).then(()=>{
cargar();
});

}

/* CARGAR PREGUNTA */
function cargar(){
let p=preguntas[i];
correcta=p.a/p.b;

document.querySelector(".pregunta h2").innerHTML =
`${p.a} ÷ ${p.b} = ?`;

hablar(`¿Cuánto es ${p.a} dividido ${p.b}?`);

let arr=[correcta];
while(arr.length<3){
let f=correcta+Math.floor(Math.random()*5)-2;
if(!arr.includes(f))arr.push(f);
}
arr.sort(()=>Math.random()-0.5);

document.querySelectorAll(".respuesta").forEach((r,j)=>{
r.textContent=arr[j];
r.dataset.val=arr[j];
});
}

/* DRAG */
document.querySelectorAll(".respuesta").forEach(r=>{
r.addEventListener("dragstart",e=>{
e.dataTransfer.setData("text",e.target.dataset.val);
});
});

document.getElementById("zonaRespuesta").addEventListener("dragover",e=>e.preventDefault());

document.getElementById("zonaRespuesta").addEventListener("drop",e=>{
let v=parseInt(e.dataTransfer.getData("text"));
validar(v);
});

function validar(v){

if(terminado)return;

if(v===correcta){

document.getElementById("bien").play();
msg.textContent="Correcto";

monoPos+=140;
mono.classList.add("walk");
mono.style.left=monoPos+"px";
setTimeout(()=>mono.classList.remove("walk"),400);

i++;
setTimeout(cargar,900);

}else{

document.getElementById("error").play();

vidas--;
document.getElementById("vidas").textContent=vidas;

msg.textContent="Incorrecto";

monoPos=Math.max(0,monoPos-60);
mono.style.left=monoPos+"px";

if(vidas<=0){
terminado=true;
msg.textContent="Perdiste";
hablar("Juego terminado");
}
}
}
</script>

</body>
</html>
