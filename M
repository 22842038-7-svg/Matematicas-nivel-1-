}

/* CONTENIDO */
.contenedor-juego{
text-align:center;
padding:25px;
}

h1{
color:white;
font-size:40px;
text-shadow:2px 2px 5px black;
}

/* VIDAS */
.vidas{
color:white;
font-size:22px;
font-weight:bold;
