<audio id="audioFelicitacion" src="audio/felicitaciones.mp3"></audio>

<script>

let preguntas = [
{txt:"6 + 4", res:10},
{txt:"8 + 3", res:11},
{txt:"9 - 2", res:7},
{txt:"5 × 2", res:10},
{txt:"12 ÷ 3", res:4}
];

let indice = 0;
let puntaje = parseInt(localStorage.getItem("puntaje")) || 0;

document.getElementById("puntos").textContent = puntaje;

window.onload = () => {

let nombre = localStorage.getItem("nombre") || "Estudiante";
let avatar = localStorage.getItem("avatar") || "img/avatar.png";

document.getElementById("nombreUsuario").textContent = nombre;
document.getElementById("avatarUsuario").src = avatar;

cargarPregunta();

};

function cargarPregunta(){

if(indice >= preguntas.length){

document.getElementById("pregunta").innerHTML =
"🏆 ¡Juego completado!";

document.getElementById("mensaje").innerHTML =
"🎉 ¡EXCELENTE TRABAJO!";

confetti({
particleCount:350,
spread:120
});

document.getElementById("audioFelicitacion").play();

document.getElementById("btnSiguiente").disabled = false;

return;
}

let p = preguntas[indice];

document.getElementById("pregunta").innerHTML = p.txt;

let opciones = [p.res];

while(opciones.length < 3){
let fake = p.res + Math.floor(Math.random()*10)-5;
if(!opciones.includes(fake) && fake >= 0){
opciones.push(fake);
}
}

opciones.sort(()=>Math.random()-0.5);

let cont = document.getElementById("opciones");
cont.innerHTML = "";

opciones.forEach(num=>{

let div = document.createElement("div");
div.className = "opcion";
div.innerText = num;

div.onclick = () => validar(div, num);

cont.appendChild(div);

});

}

function validar(div, num){

if(num === preguntas[indice].res){

div.classList.add("correctoAnim");

document.getElementById("audioCorrecto").play();

document.getElementById("mensaje").innerHTML =
"🎉 ¡CORRECTO!";

document.getElementById("mensaje").className =
"correctoText";

confetti({
particleCount:150,
spread:90
});

puntaje += 10;
localStorage.setItem("puntaje",puntaje);
document.getElementById("puntos").textContent = puntaje;

indice++;

setTimeout(()=>{
cargarPregunta();
document.getElementById("mensaje").innerHTML = "";
},900);

}else{

div.classList.add("incorrectoAnim");

document.getElementById("audioError").play();

document.getElementById("mensaje").innerHTML =
"❌ Intenta otra vez";

document.getElementById("mensaje").className =
"incorrectoText";

setTimeout(()=>{
div.classList.remove("incorrectoAnim");
},500);

}

}

function reiniciarJuego(){

indice = 0;
cargarPregunta();
document.getElementById("mensaje").innerHTML = "";
document.getElementById("btnSiguiente").disabled = true;

}

